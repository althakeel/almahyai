ADMIN_EMAIL=althakeel.com@gmail.com
DEFAULT_CHAT_MODEL=gemini-2.5-flash

# Replace <db_password> with your real password (URL-encode special chars, e.g. ! becomes %21)
MONGODB_URI=mongodb+srv://almahy_user:<db_password>@cluster0.awixodg.mongodb.net/?appName=Cluster0
MONGODB_DB=almahy-ai

# Server port
PORT=3847

# Optional: platform keys used when admin has not saved keys in the app yet
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional: Google Programmable Search (Custom Search JSON API)
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_ID=

# Guest mode: max chat requests per IP per day (no sign-in)
GUEST_REQUEST_LIMIT=20

# Optional: fixed secret so encrypted keys work across servers (use same value on PC + AWS)
# ENCRYPTION_SECRET=your-long-random-secret
