{
  "name": "orion-ai",
  "version": "1.7.8",
  "description": "Almahy AI - All-in-one AI assistant by Al Thakeel",
  "main": "dist-electron/main.js",
  "author": "Al Thakeel",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:backend": "npm run dev --prefix backend",
    "dev:all": "concurrently \"npm run dev:backend\" \"wait-on http://localhost:3847/api/health && npm run electron:dev\"",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && tsc -p tsconfig.electron.json && electron .\"",
    "electron:build": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "jspdf": "^4.2.1",
    "marked": "^18.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.orion.ai",
    "productName": "Almahy AI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/main.js",
      "dist-electron/static-server.js"
    ],
    "asar": true,
    "compression": "maximum",
    "npmRebuild": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "differentialPackage": false
    }
  }
}
